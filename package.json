{
  "name": "tdraw",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run build:server && npm run build:realtime-bundle",
    "build:server": "esbuild server/prod.entry.ts --bundle --platform=node --packages=external --format=cjs --outfile=server/prod.cjs",
    "build:realtime-bundle": "esbuild realtime/server.ts --bundle --platform=node --packages=external --format=cjs --outfile=realtime/server.bundle.cjs",
    "start": "next start",
    "start:unified": "node server/prod.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "realtime": "tsx realtime/server.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "localforage": "^1.10.0",
    "lucide-react": "^1.8.0",
    "mathjs": "^15.2.0",
    "mongoose": "^9.4.1",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.10",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tldraw": "^4.5.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
